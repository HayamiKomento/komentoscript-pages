{
  "komentoVersion": "0.1",
  "id": "hidive-watch",
  "name": "HIDIVE Watch",
  "updatedAt": "2026-03-14T00:00:00Z",
  "targets": [
    {
      "targetId": "hidive.watch",
      "match": {
        "origins": ["https://www.hidive.com"],
        "pathGlobs": ["/*watch*", "/video/*"]
      },
      "extract": {
        "animeTitle": {
          "selector": "h1",
          "attr": "text",
          "required": true,
          "transforms": ["trim"]
        },
        "episodeNumber": {
          "pipeline": [["querySelector", "h1"], ["text"], ["regex", "(\\d+)"], ["number"]],
          "required": true
        }
      },
      "placement": {
        "display": "below",
        "anchorSelector": "main",
        "mountSelector": "main",
        "sidePadding": 20
      }
    }
  ]
}
